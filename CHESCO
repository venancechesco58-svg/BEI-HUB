/* ========================================
   ROOT VARIABLES & RESET
   ======================================== */
:root {
  --primary-blue: #1E5EFF;
  --primary-blue-dark: #1444b8;
  --accent-green: #4CAF50;
  --accent-orange: #FF9800;
  --accent-red: #d63d4b;
  --white: #ffffff;
  --light-gray: #f5f5f5;
  --gray-2: #eeeeee;
  --dark-gray: #333333;
  --text-gray: #666666;
  --border-color: #e0e0e0;
  --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 4px 20px rgba(0, 0, 0, 0.12);
  --transition: all 0.3s ease;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  width: 100%;
  height: 100%;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  color: var(--dark-gray);
  background-color: var(--light-gray);
  line-height: 1.6;
}

/* ========================================
   HEADER / NAVBAR
   ======================================== */
.header {
  background: var(--white);
  padding: 1rem 1.5rem;
  box-shadow: var(--shadow);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
}

.logo-section {
  flex-shrink: 0;
}

.logo {
  text-decoration: none;
  font-size: 1.8rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  display: inline-block;
}

.logo-bei {
  color: var(--white);
  background: linear-gradient(135deg, var(--primary-blue), #1a4d99);
  padding: 0 8px;
  border-radius: 4px;
}

.logo-hub {
  color: var(--accent-green);
  font-weight: 800;
  margin-left: 2px;
}

.nav-menu {
  display: flex;
  gap: 2rem;
  flex: 1;
  align-items: center;
}

.nav-link {
  text-decoration: none;
  color: var(--dark-gray);
  font-size: 0.95rem;
  font-weight: 500;
  transition: var(--transition);
  position: relative;
  padding: 0.5rem 0;
}

.nav-link:hover {
  color: var(--primary-blue);
}

.nav-link.active {
  color: var(--primary-blue);
  font-weight: 600;
}

.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: -0.5rem;
  left: 0;
  width: 100%;
  height: 3px;
  background: var(--primary-blue);
  border-radius: 3px;
}

.header-icons {
  display: flex;
  gap: 1rem;
  align-items: center;
  flex-shrink: 0;
}

.icon-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: var(--light-gray);
  cursor: pointer;
  font-size: 1.2rem;
  transition: var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn:hover {
  background: var(--gray-2);
  transform: scale(1.05);
}

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}

.hamburger span {
  width: 25px;
  height: 3px;
  background: var(--dark-gray);
  border-radius: 2px;
  transition: var(--transition);
}

/* ========================================
   MAIN CONTAINER
   ======================================== */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
}

/* ========================================
   SEARCH SECTION
   ======================================== */
.search-section {
  margin-bottom: 3rem;
}

.search-container {
  display: flex;
  gap: 0.5rem;
  align-items: center;
  max-width: 600px;
  margin: 0 auto;
}

.search-input {
  flex: 1;
  padding: 1rem 1.5rem;
  border: 2px solid var(--border-color);
  border-radius: 10px;
  font-size: 1rem;
  transition: var(--transition);
}

.search-input:focus {
  outline: none;
  border-color: var(--primary-blue);
  box-shadow: 0 0 0 3px rgba(30, 94, 255, 0.1);
}

.search-btn {
  padding: 1rem 1.5rem;
  background: var(--primary-blue);
  color: var(--white);
  border: none;
  border-radius: 10px;
  font-size: 1.2rem;
  cursor: pointer;
  transition: var(--transition);
}

.search-btn:hover {
  background: var(--primary-blue-dark);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* ========================================
   SECTION TITLES
   ======================================== */
.section-title {
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 2rem;
  color: var(--dark-gray);
}

/* ========================================
   TRENDING PHONES SECTION
   ======================================== */
.trending-section {
  margin-bottom: 3rem;
}

.phones-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.phone-card {
  background: var(--white);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: var(--transition);
  cursor: pointer;
}

.phone-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-lg);
}

.phone-card-image {
  width: 100%;
  height: 200px;
  background: linear-gradient(135deg, #f0f4ff, #e8f0ff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
}

.phone-card-content {
  padding: 1.5rem;
  text-align: center;
}

.phone-card-name {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--dark-gray);
  margin-bottom: 0.5rem;
}

.phone-card-price {
  font-size: 0.95rem;
  color: var(--text-gray);
  margin-bottom: 1rem;
}

.phone-card-price-range {
  color: var(--primary-blue);
  font-weight: 600;
}

/* ========================================
   CATEGORY BUTTONS SECTION
   ======================================== */
.categories-section {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.category-btn {
  padding: 1.5rem;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  color: var(--white);
  text-align: center;
  flex-direction: column;
}

.category-btn:hover {
  transform: scale(1.05);
  box-shadow: var(--shadow-lg);
}

.category-blue {
  background: var(--primary-blue);
}

.category-orange {
  background: var(--accent-orange);
}

.category-red {
  background: var(--accent-red);
}

.category-icon {
  font-size: 1.8rem;
}

/* ========================================
   ARTICLES SECTION
   ======================================== */
.articles-section {
  margin-bottom: 3rem;
}

.articles-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}

.article-card {
  background: var(--white);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: var(--transition);
  cursor: pointer;
  display: flex;
  flex-direction: column;
}

.article-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-lg);
}

.article-image {
  width: 100%;
  height: 220px;
  background: linear-gradient(135deg, #fff4e6, #ffe6cc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
}

.article-content {
  padding: 1.5rem;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.article-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--dark-gray);
  margin-bottom: 0.75rem;
}

.article-description {
  font-size: 0.95rem;
  color: var(--text-gray);
  margin-bottom: 1.5rem;
  flex: 1;
}

.article-cta {
  color: var(--primary-blue);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
}

.article-cta:hover {
  gap: 1rem;
}

/* ========================================
   COMPARISON SECTION
   ======================================== */
.comparison-section {
  margin-bottom: 3rem;
}

.comparison-container {
  background: var(--white);
  border-radius: 10px;
  padding: 2rem;
  box-shadow: var(--shadow);
}

.comparison-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
  justify-content: center;
  flex-wrap: wrap;
}

.phone-select {
  flex: 1;
  min-width: 200px;
  padding: 1rem;
  border: 2px solid var(--border-color);
  border-radius: 8px;
  font-size: 1rem;
  transition: var(--transition);
  cursor: pointer;
}

.phone-select:focus {
  outline: none;
  border-color: var(--primary-blue);
  box-shadow: 0 0 0 3px rgba(30, 94, 255, 0.1);
}

.vs-text {
  font-weight: 700;
  color: var(--primary-blue);
  font-size: 1.1rem;
}

.compare-btn {
  display: block;
  margin: 0 auto;
  padding: 1rem 3rem;
  background: var(--primary-blue);
  color: var(--white);
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: var(--transition);
}

.compare-btn:hover {
  background: var(--primary-blue-dark);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* ========================================
   FOOTER
   ======================================== */
.footer {
  background: var(--dark-gray);
  color: var(--white);
  text-align: center;
  padding: 2rem;
  margin-top: 3rem;
}

/* ========================================
   RESPONSIVE DESIGN
   ======================================== */
@media (max-width: 768px) {
  /* Header adjustments */
  .header-container {
    gap: 1rem;
  }

  .nav-menu {
    display: none;
    position: absolute;
    top: 70px;
    left: 0;
    right: 0;
    background: var(--white);
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    box-shadow: var(--shadow-lg);
  }

  .nav-menu.active {
    display: flex;
  }

  .hamburger {
    display: flex;
  }

  .logo {
    font-size: 1.4rem;
  }

  /* Main container */
  .container {
    padding: 1.5rem 1rem;
  }

  /* Grids */
  .phones-grid {
    grid-template-columns: 1fr;
  }

  .articles-grid {
    grid-template-columns: 1fr;
  }

  .categories-section {
    grid-template-columns: 1fr;
  }

  /* Sections */
  .section-title {
    font-size: 1.5rem;
  }

  .search-container {
    max-width: 100%;
  }

  /* Comparison */
  .comparison-row {
    flex-direction: column;
  }

  .phone-select {
    width: 100%;
    min-width: unset;
  }
}

@media (max-width: 480px) {
  .header {
    padding: 0.75rem 1rem;
  }

  .logo {
    font-size: 1.2rem;
  }

  .header-icons {
    gap: 0.5rem;
  }

  .icon-btn {
    width: 36px;
    height: 36px;
    font-size: 1rem;
  }

  .container {
    padding: 1rem;
  }

  .section-title {
    font-size: 1.3rem;
    margin-bottom: 1.5rem;
  }

  .search-container {
    flex-direction: column;
  }

  .search-input,
  .search-btn {
    width: 100%;
  }

  .phone-card-image,
  .article-image {
    height: 150px;
  }

  .category-btn {
    padding: 1.2rem 1rem;
    font-size: 0.9rem;
  }

  .comparison-container {
    padding: 1.5rem 1rem;
  }

  .compare-btn {
    width: 100%;
    padding: 0.8rem;
  }
}

.icon-button {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.18);
  display: grid;
  place-items: center;
  color: var(--white);
  font-size: 1rem;
}

.hero {
  background: rgba(255,255,255,0.93);
  border-radius: 30px;
  padding: 28px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(12px);
}

.hero-search {
  max-width: 920px;
  margin: 0 auto;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 14px;
  background: #f8fbff;
  border: 1px solid #dfe7f4;
  border-radius: 16px;
  padding: 16px 20px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
}

.search-bar input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  font-size: 1rem;
  color: #1f2937;
}

.search-bar button {
  border: none;
  background: var(--blue-700);
  color: white;
  padding: 14px 18px;
  border-radius: 14px;
  cursor: pointer;
  font-weight: 700;
  display: grid;
  place-items: center;
  min-width: 56px;
}

.section {
  margin-top: 32px;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 18px;
  color: var(--blue-800);
  font-size: 1.05rem;
  font-weight: 700;
}

.cards-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 18px;
}

.card {
  background: white;
  border-radius: 24px;
  padding: 22px 18px;
  box-shadow: 0 18px 44px rgba(15, 51, 97, 0.08);
  border: 1px solid rgba(15, 51, 97, 0.06);
  min-height: 320px;
  position: relative;
  overflow: hidden;
}

.card img {
  width: 100%;
  height: auto;
  display: block;
  margin: 0 auto 16px;
  max-height: 170px;
  object-fit: contain;
}

.card-title {
  font-size: 1.1rem;
  margin: 0 0 10px;
  color: var(--blue-700);
  font-weight: 700;
  text-align: center;
}

.card-price {
  text-align: center;
  color: #2d3e5b;
  font-weight: 600;
  font-size: 0.96rem;
}

.button-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 24px;
}

.button-row button {
  border: none;
  border-radius: 16px;
  padding: 14px 16px;
  font-weight: 700;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  cursor: pointer;
  box-shadow: 0 16px 32px rgba(26, 88, 194, 0.16);
}

.button-row .btn-blue { background: linear-gradient(135deg, #2d65f0, #1a4acf); }
.button-row .btn-orange { background: linear-gradient(135deg, #f68d22, #e1691c); }
.button-row .btn-red { background: linear-gradient(135deg, #d63d4b, #b72334); }

.news-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.news-card {
  background: white;
  border-radius: 26px;
  padding: 22px;
  box-shadow: var(--shadow);
  display: flex;
  align-items: stretch;
  gap: 18px;
  min-height: 164px;
  border: 1px solid rgba(15, 51, 97, 0.06);
}

.news-card.large {
  min-height: 212px;
}

.news-card img {
  width: 120px;
  height: auto;
  border-radius: 18px;
  object-fit: cover;
  flex-shrink: 0;
}

.news-content {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 10px;
}

.news-content h3 {
  margin: 0;
  font-size: 1rem;
  color: #153264;
  font-weight: 700;
}

.news-content p {
  margin: 0;
  color: #475569;
  line-height: 1.5;
  font-size: 0.95rem;
}

.news-link {
  color: var(--blue-700);
  font-weight: 700;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.95rem;
}

.compare-panel {
  background: white;
  border-radius: 28px;
  box-shadow: var(--shadow);
  padding: 26px 26px 22px;
  border: 1px solid rgba(15, 51, 97, 0.06);
}

.compare-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 18px;
  align-items: center;
}

.select-box {
  background: #f8fbff;
  border: 1px solid #dfe7f4;
  border-radius: 16px;
  padding: 16px 18px;
  display: grid;
}

.select-box select {
  border: none;
  background: transparent;
  font-size: 0.98rem;
  color: #334155;
  outline: none;
  width: 100%;
  cursor: pointer;
}

.vs-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.05rem;
  color: var(--blue-800);
  font-weight: 800;
  border-radius: 18px;
  background: linear-gradient(135deg, #f8fbff, #edf4ff);
  padding: 16px 24px;
  border: 1px solid #d1e4ff;
}

.compare-btn {
  margin-top: 20px;
  width: 100%;
  display: inline-flex;
  justify-content: center;
  padding: 16px 24px;
  border: none;
  border-radius: 16px;
  background: var(--blue-700);
  color: white;
  font-weight: 700;
  cursor: pointer;
  letter-spacing: 0.02em;
  text-decoration: none;
}

.compare-hero {
  margin-top: 32px;
}

.compare-banner {
  background: linear-gradient(135deg, #1f5ce0, #f28b23);
  border-radius: 30px;
  padding: 28px;
  color: white;
  box-shadow: var(--shadow);
}

.banner-title {
  font-size: 1.15rem;
  font-weight: 800;
  margin-bottom: 22px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.banner-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 18px;
  align-items: center;
}

.phone-banner {
  background: rgba(255,255,255,0.14);
  border: 1px solid rgba(255,255,255,0.24);
  border-radius: 24px;
  padding: 22px;
  text-align: center;
}

.phone-banner img {
  width: 100%;
  max-width: 180px;
  margin: 0 auto 16px;
  border-radius: 18px;
}

.banner-phone-name {
  font-size: 1rem;
  font-weight: 800;
  margin-bottom: 8px;
}

.banner-phone-meta,
.banner-detail {
  font-size: 0.92rem;
  color: rgba(255,255,255,0.9);
  margin-bottom: 8px;
}

.vs-big {
  font-size: 3rem;
  font-weight: 900;
  color: white;
  text-shadow: 0 16px 32px rgba(0,0,0,0.2);
}

.compare-table-section {
  margin-top: 30px;
}

.result-table {
  background: white;
  border-radius: 24px;
  overflow: hidden;
  border: 1px solid rgba(15, 51, 97, 0.12);
}

.result-row {
  display: grid;
  grid-template-columns: 180px 1fr 1fr;
  gap: 1px;
  background: #edf4ff;
}

.result-row.header-row {
  background: #f8fbff;
}

.result-row.header-row > div,
.row-label,
.row-value {
  padding: 18px 20px;
}

.result-row.header-row > div {
  font-weight: 700;
  color: #0f3d96;
}

.row-label {
  background: white;
  font-weight: 700;
  color: #0f3d96;
}

.row-value {
  background: white;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.row-value.alt {
  background: #fff8ef;
}

.row-value strong {
  font-size: 0.95rem;
  color: #0f3d96;
}

.row-value span {
  color: #556987;
  font-size: 0.86rem;
}

.result-summary {
  display: grid;
  grid-template-columns: 1fr auto auto 1fr;
  gap: 18px;
  align-items: center;
  margin-top: 24px;
}

.summary-card {
  background: white;
  border-radius: 24px;
  padding: 22px;
  box-shadow: var(--shadow);
}

.summary-title {
  font-size: 0.95rem;
  font-weight: 700;
  margin-bottom: 10px;
}

.summary-phone {
  font-size: 1rem;
  font-weight: 800;
  margin-bottom: 8px;
}

.summary-text {
  color: #556987;
  font-size: 0.9rem;
  line-height: 1.4;
}

.summary-vs,
.summary-vs-divider {
  text-align: center;
}

.summary-vs {
  font-size: 2.8rem;
  font-weight: 900;
  color: #0f3d96;
}

.summary-vs span {
  font-size: 1rem;
}

.result-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 26px;
}

.action-btn {
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 16px;
  padding: 16px 24px;
  min-width: 220px;
  background: var(--blue-700);
  color: white;
  font-weight: 700;
}

.action-btn.outline {
  background: white;
  color: #0f3d96;
  border: 1px solid #cbd6ea;
}

@media (max-width: 980px) {
  .topbar {
    flex-direction: column;
    align-items: stretch;
  }
  .nav-links {
    justify-content: center;
  }
  .button-row {
    grid-template-columns: 1fr;
  }
  .news-grid {
    grid-template-columns: 1fr;
  }
  .compare-grid {
    grid-template-columns: 1fr;
  }
  .vs-chip {
    justify-content: flex-start;
  }
  .banner-grid,
  .result-summary {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 580px) {
  .page {
    padding: 18px 14px 32px;
  }
  .card {
    border-radius: 22px;
  }
  .news-card {
    flex-direction: column;
    align-items: flex-start;
  }
  .news-card img {
    width: 100%;
  }
  .compare-btn {
    width: 100%;
  }
}
